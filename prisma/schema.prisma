// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum SubRole {
  DG
  HEAD
  SECRETARY
  STAFF
  COURSE_COORDINATOR
  COURSE_INSTRUCTOR
}

enum FileStatus {
  PENDING
  IN_CIRCULATION
  REJECTED
  APPROVED
  FORWARDED
}

enum NewsStatus {
  PENDING
  PUBLISHED
}

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MagazineStatus {
  PENDING
  PUBLISHED
}

enum CourseStatus {
  DRAFT
  OPEN
  CLOSED
  IN_PROGRESS
  COMPLETED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id                 String      @id @default(uuid())
  username           String      @unique
  password           String
  role               Role        @default(ADMIN)
  sub_role           SubRole     @default(STAFF)
  department         Department  @relation(fields: [department_id], references: [id])
  department_id      String
  profile            Profile?
  files              File[]
  news               News[]
  file_logs          FileLog[]   @relation("FileLogUser")
  received_file_logs FileLog[]   @relation("FileLogToUser")
  workflows          WorkFlow[]  @relation("WorkflowUser")
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  // School / course relations
  coordinated_schools School[] @relation("SchoolCoordinator")
  instructor_schools  School[] @relation("SchoolInstructors")
  instructor_courses  Course[] @relation("CourseInstructor")
}

model Profile {
  id         String   @id @default(uuid())
  first_name String
  last_name  String
  email      String   @unique
  position   String
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Department {
  id               String     @id @default(uuid())
  name             String     @unique
  users            User[]
  originated_files File[]     @relation("FileOriginDepartment")
  current_files    File[]     @relation("FileCurrentDepartment")
  file_logs_from   FileLog[]  @relation("FileLogFromDepartment")
  file_logs_to     FileLog[]  @relation("FileLogToDepartment")
  workflows        WorkFlow[]
}

model File {
  id                    String     @id @default(uuid())
  name                  String
  file_uri              String
  owner                 User       @relation(fields: [owner_id], references: [id])
  owner_id              String
  origin_department     Department @relation("FileOriginDepartment", fields: [origin_department_id], references: [id])
  origin_department_id  String
  current_department    Department @relation("FileCurrentDepartment", fields: [current_department_id], references: [id])
  current_department_id String
  status                FileStatus @default(PENDING)
  file_logs             FileLog[]
  workflows             WorkFlow[]
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt
}

model News {
  id             String     @id @default(uuid())
  title          String
  content        String
  excerpt        String
  author         User       @relation(fields: [author_id], references: [id])
  author_id      String
  main_image_uri String
  images         String[]
  status         NewsStatus @default(PENDING)
  published_at   DateTime?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
}

model Magazine {
  id             String     @id @default(uuid())
  title          String
  content        String
  main_image_uri String
  images         String[]
  status         MagazineStatus @default(PENDING)
  published_at   DateTime?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
}

model FileLog {
  id                 String     @id @default(uuid())
  user               User       @relation("FileLogUser", fields: [user_id], references: [id])
  user_id            String
  file               File       @relation(fields: [file_id], references: [id])
  file_id            String
  from_department    Department @relation("FileLogFromDepartment", fields: [from_department_id], references: [id])
  from_department_id String
  to_department      Department @relation("FileLogToDepartment", fields: [to_department_id], references: [id])
  to_department_id   String
  to_user            User?      @relation("FileLogToUser", fields: [to_user_id], references: [id])
  to_user_id         String?
  status             FileStatus
  timestamp          DateTime   @default(now())
}

model WorkFlow {
  id            String         @id @default(uuid())
  file          File           @relation(fields: [file_id], references: [id])
  file_id       String
  department    Department     @relation(fields: [department_id], references: [id])
  department_id String
  user          User?          @relation("WorkflowUser", fields: [user_id], references: [id])
  user_id       String?
  status        WorkflowStatus @default(PENDING)
  timestamp     DateTime       @default(now())
}

model School {
  id             String   @id @default(uuid())
  name           String   @unique
  location       String
  coordinator    User     @relation("SchoolCoordinator", fields: [coordinator_id], references: [id])
  coordinator_id String

  instructors User[] @relation("SchoolInstructors")
  courses     Course[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  aluminis Alumini[]
}

model Course {
  id           String        @id @default(uuid())
  school       School        @relation(fields: [school_id], references: [id])
  school_id    String
  title        String
  description  String
  duration     String
  location     String
  year         String
  instructor   User          @relation("CourseInstructor", fields: [instructor_id], references: [id])
  instructor_id String
  status       CourseStatus  @default(DRAFT)
  start_date   DateTime

  students   Student[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  aluminis Alumini[]
}

model Student {
  id                String   @id @default(uuid())
  course            Course   @relation(fields: [course_id], references: [id])
  course_id         String
  name              String
  email             String
  phone             String
  address           String
  registration_date DateTime @default(now())
}

model Alumini {
  id                String   @id @default(uuid())
  name              String
  email             String?
  phone             String?
  address           String?
  school            School   @relation(fields: [school_id], references: [id])
  school_id         String
  course            Course   @relation(fields: [course_id], references: [id])
  course_id         String
  year_of_participation      DateTime?
  occupation        String?
  age               String?
  gender            String?
  sponsor           String?
  image_url         String?
}
